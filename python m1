import discord
from discord.ext import commands
import random

description = "Bot de ejemplo con comandos básicos"

intents = discord.Intents.default()
intents.members = True
intents.message_content = True

bot = commands.Bot(command_prefix='?', description=description, intents=intents)


@bot.event
async def on_ready():
    print(f'Logged in as {bot.user}')
    print('------')


@bot.command()
async def add(ctx, left: int, right: int):
    await ctx.send(left + right)


@bot.command()
async def roll(ctx, dice: str):
    try:
        rolls, limit = map(int, dice.split('d'))
        result = ', '.join(str(random.randint(1, limit)) for _ in range(rolls))
        await ctx.send(result)
    except:
        await ctx.send("Formato incorrecto. Usa NdN (ej: 2d6)")


@bot.command()
async def choose(ctx, *choices: str):
    if not choices:
        await ctx.send("Tenés que dar opciones.")
        return
    await ctx.send(random.choice(choices))


@bot.command()
async def repeat(ctx, times: int, *, content="repeating..."):
    if times > 5:
        await ctx.send("Máximo 5 repeticiones 😭")
        return

    for _ in range(times):
        await ctx.send(content)


@bot.command()
async def joined(ctx, member: discord.Member):
    if member.joined_at:
        await ctx.send(f'{member} entró el {discord.utils.format_dt(member.joined_at)}')
    else:
        await ctx.send("No se pudo obtener la fecha de ingreso.")


@bot.group()
async def cool(ctx):
    if ctx.invoked_subcommand is None:
        await ctx.send(f'No, {ctx.subcommand_passed} no es cool 😔')


@cool.command(name='bot')
async def _bot(ctx):
    await ctx.send('Sí, el bot es cool 😎')


# 💡 HELP PERSONALIZADO
@bot.command()
async def help(ctx):
    await ctx.send("""
🤖 COMANDOS DEL BOT:

?add a b → suma dos números
?roll NdN → tira dados (ej: 2d6)
?choose opciones → elige una opción
?repeat n texto → repite mensaje (máx 5)
?joined @usuario → muestra fecha de ingreso
?cool bot → dice si el bot es cool

💡 Ejemplo: ?add 5 3
""")


# ERROR HANDLING
@bot.event
async def on_command_error(ctx, error):
    if isinstance(error, commands.CommandNotFound):
        await ctx.send("Ese comando no existe 😭")


